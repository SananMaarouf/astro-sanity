---
import Layout from "@/layouts/Layout.astro";
import AuthorPage from "@/components/AuthorPage.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { AUTHOR_SLUGS_QUERY, AUTHOR_BY_SLUG_QUERY } from "@/sanity/lib/queries";
import { NON_DEFAULT_LOCALES, type Locale } from "@/sanity/lib/locale";

export async function getStaticPaths() {
  const { data } = await loadQuery<Array<{ slug: string }>>({
    query: AUTHOR_SLUGS_QUERY,
  });
  const slugs = data ?? [];
  const out: Array<{ params: { locale: Locale; slug: string } }> = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    for (const { slug } of slugs) out.push({ params: { locale, slug } });
  }
  return out;
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;

const { data: author } = await loadQuery<any>({
  query: AUTHOR_BY_SLUG_QUERY,
  params: { slug, locale },
});

if (!author) throw new Error(`Author not found: ${locale}/${slug}`);
---
<Layout locale={locale} title={author.name} path={`/author/${slug}`}>
  <AuthorPage author={author} locale={locale} />
</Layout>
