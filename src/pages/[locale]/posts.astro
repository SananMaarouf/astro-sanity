---
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { POSTS_INDEX_QUERY } from "@/sanity/lib/queries";
import { NON_DEFAULT_LOCALES, type Locale } from "@/sanity/lib/locale";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const { data: posts } = await loadQuery<any[]>({
  query: POSTS_INDEX_QUERY,
  params: { locale },
});
---
<Layout locale={locale} title="Posts" path="/posts">
  <section class="container mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold mb-8">Posts</h1>
    {posts?.length ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            publishedAt={post.publishedAt}
            mainImage={post.mainImage}
            locale={locale}
          />
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground">No posts yet.</p>
    )}
  </section>
</Layout>
