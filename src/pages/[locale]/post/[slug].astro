---
import Layout from "@/layouts/Layout.astro";
import PostPage from "@/components/PostPage.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { POST_SLUGS_QUERY, POST_BY_SLUG_QUERY } from "@/sanity/lib/queries";
import { NON_DEFAULT_LOCALES, type Locale } from "@/sanity/lib/locale";

export async function getStaticPaths() {
  const out: Array<{ params: { locale: Locale; slug: string } }> = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const { data } = await loadQuery<Array<{ slug: string }>>({
      query: POST_SLUGS_QUERY,
      params: { locale },
    });
    for (const { slug } of data ?? []) out.push({ params: { locale, slug } });
  }
  return out;
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;

const { data: post } = await loadQuery<any>({
  query: POST_BY_SLUG_QUERY,
  params: { slug, locale },
});

if (!post) throw new Error(`Post not found: ${locale}/${slug}`);
---
<Layout
  locale={locale}
  title={post.title}
  description={post.body?.[0]?.children?.[0]?.text}
  image={post.mainImage}
  path={`/post/${slug}`}
>
  <PostPage post={post} locale={locale} />
</Layout>
