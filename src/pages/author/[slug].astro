---
import Layout from "@/layouts/Layout.astro";
import AuthorPage from "@/components/AuthorPage.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { AUTHOR_SLUGS_QUERY, AUTHOR_BY_SLUG_QUERY } from "@/sanity/lib/queries";

export async function getStaticPaths() {
  const { data } = await loadQuery<Array<{ slug: string }>>({
    query: AUTHOR_SLUGS_QUERY,
  });
  return (data ?? []).map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const { data: author } = await loadQuery<any>({
  query: AUTHOR_BY_SLUG_QUERY,
  params: { slug },
});

if (!author) throw new Error(`Author not found: ${slug}`);
---
<Layout title={author.name} path={`/author/${slug}`}>
  <AuthorPage author={author} />
</Layout>
