---
import { loadQuery } from "@/sanity/lib/load-query";
import { FOOTER_QUERY } from "@/sanity/lib/queries";

const { data: footer } = await loadQuery<any>({
  query: FOOTER_QUERY,
});
---
<footer class="">
  <div class="container mx-auto px-4 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 text-sm">
    {footer?.address && (
      <div>
        <h3 class="font-semibold mb-2">Address</h3>
        <p class="text-muted-foreground whitespace-pre-line">{footer.address}</p>
      </div>
    )}
    {footer?.email && (
      <div>
        <h3 class="font-semibold mb-2">Email</h3>
        <a class="text-muted-foreground hover:underline" href={`mailto:${footer.email}`}>
          {footer.email}
        </a>
      </div>
    )}
    {footer?.cellNumber && (
      <div>
        <h3 class="font-semibold mb-2">Phone</h3>
        <a class="text-muted-foreground hover:underline" href={`tel:${footer.cellNumber}`}>
          {footer.cellNumber}
        </a>
      </div>
    )}
    {footer?.instagramURL && (
      <div>
        <h3 class="font-semibold mb-2">Instagram</h3>
        <a class="text-muted-foreground hover:underline" href={footer.instagramURL} rel="noopener noreferrer" target="_blank">
          @{footer.instagramURL.replace(/\/$/, "").split("/").pop()}
        </a>
      </div>
    )}
  </div>
  {footer?.copyright && (
    <div class="">
      <p class="container mx-auto px-4 py-4 text-xs text-muted-foreground text-center">
        {footer.copyright}
      </p>
    </div>
  )}
</footer>
