---
import { loadQuery } from "@/sanity/lib/load-query";
import { SITE_SETTINGS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

interface Props {
  title?: string;
  description?: string;
  image?: { asset?: any; alt?: string };
  path?: string;
}

const { title, description, image, path = "/" } = Astro.props;

const { data: settings } = await loadQuery<any>({
  query: SITE_SETTINGS_QUERY,
});

const siteTitle = settings?.title ?? "Astro + Sanity";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const desc = description ?? settings?.description ?? "";
const baseUrl = settings?.siteUrl ?? Astro.site?.toString().replace(/\/$/, "") ?? "";

const imgSource = image?.asset ?? settings?.ogImage?.asset;
const ogImageUrl = imgSource
  ? urlForImage(imgSource).width(1200).height(630).fit("crop").url()
  : undefined;

const canonical = `${baseUrl}${path}`;
---
<title>{fullTitle}</title>
<meta name="description" content={desc} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={desc} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
